# Copy to .env and fill in. .env is never committed.

# Shared password for the team (HTTP basic auth, username "team")
BAG_PIPELINE_PASSWORD=change-me

# Optional: override the basic-auth username (default "team")
# BAG_PIPELINE_USER=team

# Stage 2 (analyze) — Anthropic API key
ANTHROPIC_API_KEY=

# Stage 3 (push) — Shopify custom app credentials
SHOPIFY_STORE_URL=
SHOPIFY_ADMIN_TOKEN=
