# ecomm-pipeline reads Shopify credentials from the REPO-ROOT .env (shared with
# the rest of the repo). You normally do NOT need a .env in this folder.
#
# Required in the repo-root .env (already present there):
#   SHOPIFY_SHOP=paststudies.myshopify.com
#   SHOPIFY_CLIENT_ID=...
#   SHOPIFY_CLIENT_SECRET=...
#
# Optional — add a Custom App token instead of / alongside the OAuth pair
# (never expires; simplest for an unattended pipeline). get_token() prefers a
# fresh client_credentials token but will fall back to this:
#   SHOPIFY_ADMIN_TOKEN=shpat_...
#
# Optional ECOMM_* overrides (defaults shown):
#   ECOMM_API_VERSION=2025-01
#   ECOMM_COMPLETE_TAG=photos-complete
#   ECOMM_TEMPLATE=listing-standard
